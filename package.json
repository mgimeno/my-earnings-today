{
  "name": "my-earnings-today",
  "sideEffects": [
    "src/polyfills.ts"
  ],
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:production": "ng build --configuration production",
    "build:prod": "ng build --configuration production && npm run pre-brotli:dist",
    "pre-gzip:dist": "node scripts/pre-gzip-dist.mjs",
    "pre-brotli:dist": "node scripts/pre-brotli-dist.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:styles": "stylelint \"src/**/*.scss\"",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check-all-updatable-dependencies": "npx npm-check-updates -u",
    "update-all-dependencies": "npx npm-check-updates -u && npm i -f"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 iOS versions",
    "last 2 ChromeAndroid versions",
    "Firefox ESR"
  ],
  "private": true,
  "dependencies": {
    "@angular/cdk": "^22.0.1",
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/localize": "^22.0.1",
    "@angular/material": "^22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/router": "^22.0.1",
    "@fontsource/montserrat": "^5.2.8",
    "chart.js": "^4.5.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.1",
    "@angular/cli": "22.0.1",
    "@angular/compiler-cli": "^22.0.1",
    "@angular/language-service": "^22.0.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "angular-eslint": "^22.0.0",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "stylelint": "^17.13.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.2.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
